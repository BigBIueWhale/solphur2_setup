# solphur2_setup — single source of truth for every pin in this project.
#
# Every Dockerfile, docker-compose service, and shell script must `source` this
# file and reference these names exactly. Do not duplicate a version literal
# anywhere else in the project. To upgrade a component:
#   1. Edit ONE line below.
#   2. Re-derive any model SHA-256 pins (scripts/refresh_model_hashes.sh).
#   3. Rebuild the affected Docker image(s).
#
# Hardware/host assumptions (validated 2026-05-11):
#   - NVIDIA GeForce RTX 5090 graphics card (compute capability sm_120, Blackwell architecture)
#   - 32607 MiB GDDR7 VRAM
#   - NVIDIA proprietary driver 595.58.03 (open kernel module variant)
#   - Host CUDA 13.0.3
#   - NVIDIA Container Toolkit 1.19.0-1 on the host
#   - Docker CE 29.4.1
#   - Ubuntu 24.04.3 LTS host
#   - Display routed through the Intel iGPU motherboard output (NOT the RTX 5090's outputs)
#     — this is what makes the full 32607 MiB available for compute.

# ─── Container base ──────────────────────────────────────────────────────────
CUDA_BASE_IMAGE=nvidia/cuda:13.0.2-cudnn-devel-ubuntu24.04
PYTHON_VERSION=3.12.13

# ─── PyTorch stack (Blackwell sm_120 native binary) ──────────────────────────
# PyTorch 2.11.0 cu130 wheel TORCH_CUDA_ARCH_LIST = "7.5;8.0;8.6;9.0;10.0;12.0"
# sm_120 is in the binary, not PTX, per
# https://github.com/pytorch/pytorch/blob/v2.11.0/.ci/manywheel/build_cuda.sh#L107-L111
TORCH_VERSION=2.11.0+cu130
TORCHVISION_VERSION=0.26.0+cu130
TORCHAUDIO_VERSION=2.11.0+cu130
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
TRITON_VERSION=3.6.0

# ─── ComfyUI core (FP8 Blackwell fix included at this tag) ───────────────────
# https://github.com/comfyanonymous/ComfyUI/releases/tag/v0.21.0
# Includes commit e2ddf28d "Fix some fp8 scaled checkpoints no longer working"
# (#13239, 2026-03-31), which closes the post-#11920 regression on Blackwell.
COMFYUI_REPO=https://github.com/comfyanonymous/ComfyUI
COMFYUI_REF=v0.21.0
COMFYUI_SHA=52976f3ea33c

# ─── ComfyUI-LTXVideo (Lightricks custom node pack) ──────────────────────────
# Master HEAD on 2026-05-11. The repo has never tagged a release; pin by SHA.
# Contains low_vram_loaders.py (LowVRAMCheckpointLoader etc.) which lets the
# transformer + Gemma3 text encoder + VAE fit in ≤32 GiB on this card.
LTXVIDEO_NODES_REPO=https://github.com/Lightricks/ComfyUI-LTXVideo
LTXVIDEO_NODES_SHA=229437c6b657

# ─── ComfyUI-KJNodes ─────────────────────────────────────────────────────────
# Tag 1.4.0 (commit 1252598b41be, 2026-05-05). MUST be ≥ commit 0e173bbfa9de
# ("LTX2_NAG: Better dtype cast", 2026-01-17) which routes through
# manual_cast_dtype and fixes the addmm_cuda Float8_e4m3fn crash on Blackwell.
# https://github.com/kijai/ComfyUI-KJNodes/issues/505
# Provides PathchSageAttentionKJ (sic), used in Sulphur's distilled workflow.
KJNODES_REPO=https://github.com/kijai/ComfyUI-KJNodes
KJNODES_REF=1.4.0
KJNODES_SHA=1252598b41be

# ─── ComfyMath (for ComfyMathExpression node in Sulphur's workflow) ──────────
COMFYMATH_REPO=https://github.com/evanspearman/ComfyMath
COMFYMATH_SHA=be9beae9eeeb049db35e3ddd35ed1ed0058d6b59

# ─── SageAttention 2.2.0 (no Linux/Blackwell prebuilt wheel exists) ──────────
# Built from source inside the comfyui container against the torch+CUDA above.
SAGEATTENTION_REPO=https://github.com/thu-ml/SageAttention
SAGEATTENTION_REF=v2.2.0
SAGEATTENTION_SHA=eb615cf6cf4d

# ─── Python libs (ComfyUI-LTXVideo requirements + API stack) ─────────────────
TRANSFORMERS_VERSION=5.8.0
DIFFUSERS_VERSION=0.38.0
ACCELERATE_VERSION=1.13.0
SAFETENSORS_VERSION=0.7.0
EINOPS_VERSION=0.8.1
KORNIA_VERSION=0.7.4
NINJA_VERSION=1.11.1.4
HUGGINGFACE_HUB_VERSION=1.14.0

FASTAPI_VERSION=0.136.1
UVICORN_VERSION=0.46.0
HTTPX_VERSION=0.28.1

# ─── llama.cpp (CPU-only build for the Sulphur Qwen3-VL prompt enhancer) ─────
# Qwen3-VL multimodal support landed in PR #16780 (commit d261223, 2025-10-30);
# first release tag carrying it: b6887. Tag b9106 is the 2026-05-11 stable.
LLAMACPP_REPO=https://github.com/ggml-org/llama.cpp
LLAMACPP_REF=b9106
LLAMACPP_SHA=b9106

# ─── Model files (SHA-256 = LFS oid, from huggingface.co/api/models/...) ─────
# === Sulphur-2-base (https://huggingface.co/SulphurAI/Sulphur-2-base) ===
SULPHUR_FP8MIXED_PATH=sulphur_dev_fp8mixed.safetensors
SULPHUR_FP8MIXED_SIZE=29161842846
SULPHUR_FP8MIXED_SHA256=41c999575859c528ff108022246a5524960a778c18742696971c9b0aadb4f70f
SULPHUR_FP8MIXED_URL=https://huggingface.co/SulphurAI/Sulphur-2-base/resolve/main/sulphur_dev_fp8mixed.safetensors

PROMPT_ENHANCER_GGUF_PATH=prompt_enhancer/sulphur_prompt_enhancer_model-q8_0.gguf
PROMPT_ENHANCER_GGUF_SIZE=9527501184
PROMPT_ENHANCER_GGUF_SHA256=6d424c85d5ecc6945af90295b7a68f9b141ef412ae1a2acd1f7b778bd65fa78c
PROMPT_ENHANCER_GGUF_URL=https://huggingface.co/SulphurAI/Sulphur-2-base/resolve/main/prompt_enhancer/sulphur_prompt_enhancer_model-q8_0.gguf

PROMPT_ENHANCER_MMPROJ_PATH=prompt_enhancer/mmproj-BF16.gguf
PROMPT_ENHANCER_MMPROJ_SIZE=921705024
PROMPT_ENHANCER_MMPROJ_SHA256=853698ce7aa6c7ba732478bad280240969ddf7b0fcbf93900046f63903a83383
PROMPT_ENHANCER_MMPROJ_URL=https://huggingface.co/SulphurAI/Sulphur-2-base/resolve/main/prompt_enhancer/mmproj-BF16.gguf

# === LTX-2.3 distill LoRA + spatial upscaler (Lightricks/LTX-2.3) ===
LTX_DISTILL_LORA_PATH=ltx-2.3-22b-distilled-lora-384-1.1.safetensors
LTX_DISTILL_LORA_SIZE=7605507256
LTX_DISTILL_LORA_SHA256=f5d4953f3386197a4b4f5abdb17616ff256171e8075c111d6e7d2dfa6e823b3a
LTX_DISTILL_LORA_URL=https://huggingface.co/Lightricks/LTX-2.3/resolve/main/ltx-2.3-22b-distilled-lora-384-1.1.safetensors

LTX_SPATIAL_UPSCALER_PATH=ltx-2.3-spatial-upscaler-x2-1.1.safetensors
LTX_SPATIAL_UPSCALER_SIZE=995743560
LTX_SPATIAL_UPSCALER_SHA256=5f416311fa8172b65af67530758964708d29a317b830d689a51143b7f91913ed
LTX_SPATIAL_UPSCALER_URL=https://huggingface.co/Lightricks/LTX-2.3/resolve/main/ltx-2.3-spatial-upscaler-x2-1.1.safetensors

# === Comfy-Org packaged Gemma3 text encoder — FP8-scaled single-file form ===
# Sidesteps the multimodal-Gemma3 code path in comfy/text_encoders/llama.py
# that triggers issue #11920 on Blackwell when paired with FP8 transformer.
GEMMA3_TEXT_ENCODER_PATH=gemma_3_12B_it_fp8_scaled.safetensors
GEMMA3_TEXT_ENCODER_SIZE=13205434827
GEMMA3_TEXT_ENCODER_SHA256=60216ce97c01c3a8753c2dfd0a89fc76e16fbe446d1a32ef8f1b528ac8bae466
GEMMA3_TEXT_ENCODER_URL=https://huggingface.co/Comfy-Org/ltx-2/resolve/main/split_files/text_encoders/gemma_3_12B_it_fp8_scaled.safetensors
